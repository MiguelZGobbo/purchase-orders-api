# Arquivo principal da aplicacao
FLASK_APP=app.py

# Ambiente de execucao (development, testing, production)
FLASK_ENV=development

# URI de conexao com o banco de dados
# Formato: postgresql://usuario:senha@host:porta/nome_do_banco
DB_URI=postgresql://usuario:senha@localhost:1111/nome_do_banco

# Chave secreta para geracao de tokens JWT
JWT_SECRET_KEY=sua_chave_secreta_aqui
